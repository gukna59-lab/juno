// Полностью очищаем память в браузере
state.users = [];
state.chats = [];
state.messages = {};
state.presence = {};
state.typing = {};
state.calls = {};
state.currentUser = null;
currentUser = null;

// Сохраняем и принудительно отправляем пустой стейт на сервер
localStorage.setItem("juno-state-v2", JSON.stringify(state));
if (typeof pushSharedState === "function") {
    pushSharedState().then(() => {
        console.log("База данных на сервере успешно очищена!");
        location.reload();
    });
} else {
    location.reload();
}
